# Supabase local (run: supabase start && supabase status)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# FastAPI backend
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=/api/backend

# Local-first dev user (matches supabase/seed.sql)
LOCAL_USER_ID=00000000-0000-4000-8000-000000000001
NEXT_PUBLIC_LOCAL_USER_ID=00000000-0000-4000-8000-000000000001

# Stockfish — folder or full path to .exe
STOCKFISH_PATH=C:\Users\user\Documents\stockfish
ANALYSIS_DEPTH=18

# Brilliant detection thresholds (tunable)
BRILLIANT_EVAL_MARGIN=0.3
BRILLIANT_WINNING_MARGIN=3.0

# Chess.com API (public, no key required)
CHESS_COM_API_BASE=https://api.chess.com/pub
